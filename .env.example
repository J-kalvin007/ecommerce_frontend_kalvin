# ======================================================================
#  .env.example — Template for environment variables
#  !! Copy this file to .env.production and NEVER commit the real values !!
# ======================================================================

# ── Build-time (baked into the JS bundle — prefix: NEXT_PUBLIC_) ─────
# These are used by the browser. Do NOT put secrets here.

# Base URL of the Django backend API
NEXT_PUBLIC_API_URL=https://your-api.yourdomain.com

# Canonical URL of this frontend app
NEXT_PUBLIC_APP_URL=https://your-frontend.yourdomain.com

# Google Maps JavaScript API key (restrict to your domain in GCP console)
NEXT_PUBLIC_GOOGLE_MAP_KEY=AIza...

# ── Runtime secrets (server-side only — never exposed to the browser) ─

# NextAuth / session secret (openssl rand -base64 32)
NEXTAUTH_SECRET=change_me_use_openssl_rand_base64_32

# Canonical frontend URL (used by NextAuth for callback URLs)
NEXTAUTH_URL=https://your-frontend.yourdomain.com

# ── Docker image tag (used by docker-compose) ────────────────────────
# Set to a git SHA or semantic version in CI/CD
IMAGE_TAG=latest
